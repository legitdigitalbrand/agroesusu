# ==========================================
# REQUIRED — Supabase (set these in Vercel)
# ==========================================
# Get these from: https://supabase.com/dashboard/project/vhzsnsovfjnztawzuueo/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://vhzsnsovfjnztawzuueo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ==========================================
# OPTIONAL — Safe Haven Banking API (sandbox works without keys)
# ==========================================
SAFE_HAVEN_ENV=sandbox
# SAFE_HAVEN_API_KEY=your_api_key_here
# SAFE_HAVEN_SECRET_KEY=your_secret_key_here
# SAFE_HAVEN_WEBHOOK_SECRET=your_webhook_secret_here

# ==========================================
# OPTIONAL — Resend (Email notifications)
# ==========================================
# RESEND_API_KEY=your_resend_key_here

# ==========================================
# OPTIONAL — App URL
# ==========================================
NEXT_PUBLIC_APP_URL=https://agroesusu-repo.vercel.app

# ==========================================
# OPTIONAL — Cron job auth
# ==========================================
CRON_SECRET=your_cron_secret_here
