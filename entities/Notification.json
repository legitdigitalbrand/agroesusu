{
  "properties": {
    "user_id": {
      "type": "string",
      "description": "Reference to User"
    },
    "type": {
      "type": "string",
      "enum": [
        "reminder",
        "transaction",
        "payout",
        "group_update",
        "system",
        "marketing"
      ],
      "description": "Notification type"
    },
    "channel": {
      "type": "string",
      "enum": [
        "sms",
        "whatsapp",
        "email",
        "in_app"
      ],
      "description": "Delivery channel"
    },
    "title": {
      "type": "string"
    },
    "content": {
      "type": "string",
      "description": "Notification message content"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "sent",
        "failed",
        "read"
      ],
      "default": "pending"
    },
    "sent_date": {
      "type": "string",
      "format": "date-time"
    },
    "read_date": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "string",
      "description": "JSON string with extra context"
    }
  },
  "type": "object",
  "required": [
    "user_id",
    "type",
    "channel",
    "content"
  ],
  "name": "Notification"
}