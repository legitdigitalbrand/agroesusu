{
  "properties": {
    "name": {
      "type": "string",
      "description": "Group name"
    },
    "admin_id": {
      "type": "string",
      "description": "Reference to User (group admin)"
    },
    "type": {
      "type": "string",
      "enum": [
        "cycle",
        "challenge",
        "emergency"
      ],
      "default": "cycle",
      "description": "Type of group savings"
    },
    "contribution_amount": {
      "type": "number",
      "description": "Amount each member contributes per cycle"
    },
    "frequency": {
      "type": "string",
      "enum": [
        "daily",
        "weekly",
        "monthly"
      ],
      "default": "monthly"
    },
    "member_count": {
      "type": "number",
      "default": 0,
      "description": "Current number of members"
    },
    "max_members": {
      "type": "number",
      "description": "Maximum allowed members"
    },
    "payout_method": {
      "type": "string",
      "enum": [
        "fixed_rotation",
        "priority_by_need",
        "smart_rotation"
      ],
      "default": "fixed_rotation"
    },
    "current_cycle": {
      "type": "number",
      "default": 0
    },
    "total_cycles": {
      "type": "number",
      "description": "Total cycles (usually equals member count for rotation)"
    },
    "start_date": {
      "type": "string",
      "format": "date-time"
    },
    "end_date": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "forming",
        "active",
        "paused",
        "completed",
        "cancelled"
      ],
      "default": "forming"
    },
    "description": {
      "type": "string"
    },
    "total_pool": {
      "type": "number",
      "default": 0,
      "description": "Total amount saved in group"
    }
  },
  "type": "object",
  "required": [
    "name",
    "admin_id",
    "type",
    "contribution_amount"
  ],
  "name": "SavingsGroup"
}