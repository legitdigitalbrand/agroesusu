{
  "properties": {
    "user_id": {
      "type": "string",
      "description": "Reference to User"
    },
    "account_id": {
      "type": "string",
      "description": "Reference to SavingsAccount"
    },
    "type": {
      "type": "string",
      "enum": [
        "deposit",
        "withdrawal",
        "interest",
        "fee",
        "penalty",
        "bonus"
      ],
      "description": "Transaction type"
    },
    "amount": {
      "type": "number",
      "minimum": 0
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "card",
        "transfer",
        "ussd",
        "bank"
      ],
      "description": "How payment was made"
    },
    "payment_reference": {
      "type": "string",
      "description": "Paystack/Flutterwave transaction reference"
    },
    "paystack_response": {
      "type": "string",
      "description": "Raw payment gateway response (JSON)"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "completed",
        "failed",
        "reversed"
      ],
      "default": "pending"
    },
    "description": {
      "type": "string",
      "description": "Human-readable transaction description"
    },
    "fee_amount": {
      "type": "number",
      "default": 0,
      "description": "Transaction fee charged"
    },
    "completed_date": {
      "type": "string",
      "format": "date-time"
    }
  },
  "type": "object",
  "required": [
    "user_id",
    "type",
    "amount"
  ],
  "name": "Transaction"
}