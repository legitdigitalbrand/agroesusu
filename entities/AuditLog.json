{
  "properties": {
    "entity_type": {
      "type": "string",
      "description": "Type of entity affected (User, SavingsAccount, Transaction, etc.)"
    },
    "entity_id": {
      "type": "string",
      "description": "ID of affected entity"
    },
    "actor_id": {
      "type": "string",
      "description": "User ID of who performed the action"
    },
    "action": {
      "type": "string",
      "description": "What happened (create, update, delete, deposit, withdraw, etc.)"
    },
    "details": {
      "type": "string",
      "description": "JSON string with action details"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "critical"
      ],
      "default": "info"
    },
    "ip_address": {
      "type": "string"
    }
  },
  "type": "object",
  "required": [
    "entity_type",
    "action"
  ],
  "name": "AuditLog"
}