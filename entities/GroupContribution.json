{
  "properties": {
    "group_id": {
      "type": "string",
      "description": "Reference to SavingsGroup"
    },
    "user_id": {
      "type": "string",
      "description": "Reference to User (contributor)"
    },
    "cycle_number": {
      "type": "number",
      "description": "Which cycle this contribution belongs to"
    },
    "amount": {
      "type": "number"
    },
    "payment_reference": {
      "type": "string",
      "description": "Payment gateway reference"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "paid",
        "verified",
        "defaulted",
        "late"
      ],
      "default": "pending"
    },
    "paid_date": {
      "type": "string",
      "format": "date-time"
    },
    "verified_date": {
      "type": "string",
      "format": "date-time"
    },
    "verified_by": {
      "type": "string",
      "description": "User ID of who verified the payment"
    },
    "notes": {
      "type": "string"
    }
  },
  "type": "object",
  "required": [
    "group_id",
    "user_id",
    "cycle_number",
    "amount"
  ],
  "name": "GroupContribution"
}