{
  "properties": {
    "group_id": {
      "type": "string",
      "description": "Reference to SavingsGroup"
    },
    "user_id": {
      "type": "string",
      "description": "Reference to User"
    },
    "slot_position": {
      "type": "number",
      "description": "Payout order position (1 = first to receive)"
    },
    "status": {
      "type": "string",
      "enum": [
        "invited",
        "active",
        "removed",
        "left"
      ],
      "default": "invited"
    },
    "reliability_rating": {
      "type": "number",
      "default": 0,
      "minimum": 0,
      "maximum": 5,
      "description": "Average peer rating after cycles"
    },
    "has_received_payout": {
      "type": "boolean",
      "default": false
    },
    "joined_date": {
      "type": "string",
      "format": "date-time"
    },
    "invited_by": {
      "type": "string",
      "description": "User ID of who invited them"
    }
  },
  "type": "object",
  "required": [
    "group_id",
    "user_id"
  ],
  "name": "GroupMember"
}